# Interfaces: "telegram,web" (default), "web", "telegram", or "web,discord"
ENABLED_INTERFACES=telegram,web

BOT_TOKEN=seu_token_aqui
REQUEST_TIMEOUT=3600
MAX_FILE_SIZE_MB=50
MAX_PAGES=50
MAX_PAGE_WIDTH=1600
JPG_QUALITY=85
PDF_SPLIT_DPI=150
PYMUPDF_TEXT_THRESHOLD=100
TESSERACT_CMD=tesseract

TEMP_DIR=temp
DATA_DIR=data
LOGS_DIR=logs

LOG_LEVEL=INFO

# AI Client: "ollama" (Ollama), "openrouter" (OpenRouter)
AI_CLIENT=ollama

# Structurer: "pymupdf" (padrao, rapido) ou "docling" (mais preciso, requer GPU)
# Docling detecta tabelas, figuras, formulas e tem OCR nativo
# Requer: pip install docling (adiciona ~2-4GB de dependencias)
STRUCTURER=pymupdf
OLLAMA_API_KEY=sua_chave_aqui
OLLAMA_MODEL=nome-do-modelo
OLLAMA_BASE_URL=http://example.com:porta-aqui-se-diferente-da-padrao/v1/chat/completions
OPENROUTER_API_KEY=sk-or-v1-sua_chave_aqui
OPENROUTER_MODEL=nome-do-modelo
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=a11y-devs-describer

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app
SMTP_FROM=seu_email@gmail.com
SMTP_NAME=A11y Acessibilidade

# Web URL (public URL for download links in emails)
WEB_URL=sua_url_publica_aqui
