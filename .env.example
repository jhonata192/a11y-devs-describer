BOT_TOKEN=seu_token_aqui
OPENCODE_URL=http://127.0.0.1:4096
OPENCODE_MODEL=qwen3.6-plus-free
REQUEST_TIMEOUT=3600
MAX_FILE_SIZE_MB=50
MAX_PAGES=50
MAX_PAGE_WIDTH=1600
JPG_QUALITY=85
PDF_SPLIT_DPI=150
PYMUPDF_TEXT_THRESHOLD=100
TESSERACT_CMD=tesseract

TEMP_DIR=temp
DATA_DIR=data
LOGS_DIR=logs

LOG_LEVEL=INFO

# AI Client: "openrouter", "opencode" (OpenCode serve), "browser" (Playwright + gemini.google.com) or "ollama"
AI_CLIENT=openrouter
OPENROUTER_API_KEY=sua_chave_aqui
OPENROUTER_MODEL=qwen/qwen3-vl-8b-instruct
OPENROUTER_MAX_TOKENS=5000
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=a11y-devs-describer
GEMINI_URL=https://gemini.google.com/app
BROWSER_HEADLESS=true
OLLAMA_API_KEY=sua_chave_aqui
OLLAMA_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app
SMTP_FROM=seu_email@gmail.com
SMTP_NAME=A11y Acessibilidade
